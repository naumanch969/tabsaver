{
  "manifest_version": 3,
  "name": "tabsaver",
  "description": "Professional workspace manager with Obsidian Gold aesthetics and auto-snapshot protection.",
  "version": "1.1.0",
  "action": {
    "default_popup": "index.html",
    "default_icon": "icons/logo.svg"
  },
  "icons": {
    "16": "icons/logo.svg",
    "32": "icons/logo.svg",
    "48": "icons/logo.svg",
    "128": "icons/logo.svg"
  },
  "permissions": [
    "tabs",
    "storage",
    "windows",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}