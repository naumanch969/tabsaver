{
  "manifest_version": 3,
  "name": "tabsaver",
  "description": "Professional workspace manager with Obsidian Gold aesthetics and auto-snapshot protection.",
  "version": "1.1.0",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "tabs",
    "storage",
    "windows",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}